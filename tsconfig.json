{
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "target": "es2021",
    "module": "nodenext",
    "rootDir": "./src",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["./src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}
